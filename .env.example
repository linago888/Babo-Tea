# ─────────────────────────────────────────────────────────────
# Global Boba Graph — 環境變數樣板
# 複製成 .env.local（不會進 git）填入真實值
# ─────────────────────────────────────────────────────────────

# Postgres（Supabase / Neon / 本機皆可）
# pooled connection（runtime 用，Prisma client 走這個）
DATABASE_URL="postgresql://postgres:password@localhost:5432/boba_graph?schema=public&pgbouncer=true"
# direct connection（Prisma migrate 用，跳過 pooler）
DIRECT_URL="postgresql://postgres:password@localhost:5432/boba_graph?schema=public"

# Payload CMS
PAYLOAD_SECRET="replace-with-openssl-rand-base64-32"
PAYLOAD_PUBLIC_SERVER_URL="http://localhost:3000"

# Next.js
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="zh-TW"

# 媒體儲存（Phase 2+ 使用，先留空）
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="media"

# Analytics / 監控（Phase 5 上線時填）
SENTRY_DSN=""

# 編輯儀表板 admin 登入（Phase 4 /admin/*）
# 兩個都未設時 /admin 完全鎖死，不開放任何訪問
ADMIN_USER="editor"
ADMIN_PASSWORD=""
